# tool: scribe-data
# All Arabic (Q13955) verbs (Q24905) and the given forms.
# Enter this query at https://query.wikidata.org/.

SELECT
  (REPLACE(STR(?lexeme), "http://www.wikidata.org/entity/", "") AS ?lexemeID)
  ?lastModified
  ?verb
  ?masculineActivePresentThirdPersonDual
  ?masculineActiveSecondPersonSingularSubjunctive
  ?masculineActiveSecondPersonPluralSubjunctive
  ?masculineActiveThirdPersonSingularSubjunctive
  ?masculineActivePresentThirdPersonSingularSubjunctive
  ?masculineActivePresentThirdPersonPluralSubjunctive

WHERE {
  ?lexeme dct:language wd:Q13955 ;
    wikibase:lexicalCategory wd:Q24905 ;
    wikibase:lemma ?verb ;
    schema:dateModified ?lastModified .
    
  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?masculineActivePresentThirdPersonDualForm .
    ?masculineActivePresentThirdPersonDualForm ontolex:representation ?masculineActivePresentThirdPersonDual ;
      wikibase:grammaticalFeature wd:Q499327, wd:Q1317831, wd:Q192613, wd:Q51929074, wd:Q110022 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?masculineActiveSecondPersonSingularSubjunctiveForm .
    ?masculineActiveSecondPersonSingularSubjunctiveForm ontolex:representation ?masculineActiveSecondPersonSingularSubjunctive ;
      wikibase:grammaticalFeature wd:Q499327, wd:Q1317831, wd:Q51929049, wd:Q110786, wd:Q473746 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?masculineActiveSecondPersonPluralSubjunctiveForm .
    ?masculineActiveSecondPersonPluralSubjunctiveForm ontolex:representation ?masculineActiveSecondPersonPluralSubjunctive ;
      wikibase:grammaticalFeature wd:Q499327, wd:Q1317831, wd:Q51929049, wd:Q146786, wd:Q473746 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?masculineActiveThirdPersonSingularSubjunctiveForm .
    ?masculineActiveThirdPersonSingularSubjunctiveForm ontolex:representation ?masculineActiveThirdPersonSingularSubjunctive ;
      wikibase:grammaticalFeature wd:Q499327, wd:Q1317831, wd:Q51929074, wd:Q110786, wd:Q473746 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?masculineActivePresentThirdPersonSingularSubjunctiveForm .
    ?masculineActivePresentThirdPersonSingularSubjunctiveForm ontolex:representation ?masculineActivePresentThirdPersonSingularSubjunctive ;
      wikibase:grammaticalFeature wd:Q499327, wd:Q1317831, wd:Q192613, wd:Q51929074, wd:Q110786, wd:Q473746 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?masculineActivePresentThirdPersonPluralSubjunctiveForm .
    ?masculineActivePresentThirdPersonPluralSubjunctiveForm ontolex:representation ?masculineActivePresentThirdPersonPluralSubjunctive ;
      wikibase:grammaticalFeature wd:Q499327, wd:Q1317831, wd:Q192613, wd:Q51929074, wd:Q146786, wd:Q473746 .
  }
}

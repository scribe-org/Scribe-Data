# tool: scribe-data
# All Arabic (Q13955) verbs (Q24905) and the given forms.
# Enter this query at https://query.wikidata.org/.

SELECT
  (REPLACE(STR(?lexeme), "http://www.wikidata.org/entity/", "") AS ?lexemeID)
  ?lastModified
  ?verb
  ?femininePassivePresentSecondPersonSingular
  ?femininePassivePresentThirdPersonDual
  ?femininePassivePastSecondPersonSingular
  ?femininePassivePastThirdPersonDual
  ?femininePassiveSecondPersonSingularSubjunctive
  ?femininePassiveThirdPersonSingularSubjunctive

WHERE {
  ?lexeme dct:language wd:Q13955 ;
    wikibase:lexicalCategory wd:Q24905 ;
    wikibase:lemma ?verb ;
    schema:dateModified ?lastModified .
    
  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?femininePassivePresentSecondPersonSingularForm .
    ?femininePassivePresentSecondPersonSingularForm ontolex:representation ?femininePassivePresentSecondPersonSingular ;
      wikibase:grammaticalFeature wd:Q1775415, wd:Q1194697, wd:Q192613, wd:Q51929049, wd:Q110786 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?femininePassivePresentThirdPersonDualForm .
    ?femininePassivePresentThirdPersonDualForm ontolex:representation ?femininePassivePresentThirdPersonDual ;
      wikibase:grammaticalFeature wd:Q1775415, wd:Q1194697, wd:Q192613, wd:Q51929074, wd:Q110022 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?femininePassivePastSecondPersonSingularForm .
    ?femininePassivePastSecondPersonSingularForm ontolex:representation ?femininePassivePastSecondPersonSingular ;
      wikibase:grammaticalFeature wd:Q1775415, wd:Q1194697, wd:Q1994301, wd:Q51929049, wd:Q110786 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?femininePassivePastThirdPersonDualForm .
    ?femininePassivePastThirdPersonDualForm ontolex:representation ?femininePassivePastThirdPersonDual ;
      wikibase:grammaticalFeature wd:Q1775415, wd:Q1194697, wd:Q1994301, wd:Q51929074, wd:Q110022 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?femininePassiveSecondPersonSingularSubjunctiveForm .
    ?femininePassiveSecondPersonSingularSubjunctiveForm ontolex:representation ?femininePassiveSecondPersonSingularSubjunctive ;
      wikibase:grammaticalFeature wd:Q1775415, wd:Q1194697, wd:Q51929049, wd:Q110786, wd:Q473746 .
  }

  OPTIONAL {
    ?lexeme ontolex:lexicalForm ?femininePassiveThirdPersonSingularSubjunctiveForm .
    ?femininePassiveThirdPersonSingularSubjunctiveForm ontolex:representation ?femininePassiveThirdPersonSingularSubjunctive ;
      wikibase:grammaticalFeature wd:Q1775415, wd:Q1194697, wd:Q51929074, wd:Q110786, wd:Q473746 .
  }
}
